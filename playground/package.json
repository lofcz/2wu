{
  "name": "playground",
  "version": "1.0.18",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "bun run build && vite preview",
    "analyze": "bun run --filter \"reactjs-tiptap-editor\" lint && tsc && vite build --mode=analyze && source-map-explorer \"dist/assets/*.js\"",
    "release": "bumpp -r"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "reactjs-tiptap-editor": "file:.."
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@react-scan/vite-plugin-react-scan": "^0.2.3",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "@vitejs/plugin-react": "^6.0.1",
    "bumpp": "^9.11.1",
    "git-scm-hooks": "^0.0.11",
    "react-scan": "^0.5.3",
    "sass": "^1.86.2",
    "source-map-explorer": "^2.5.3",
    "typescript": "^5.8.2",
    "vite": "^8.0.0"
  }
}
